format = """
[Óā∂](#A29718)\
$os\
$username\
[Óāį](bg:#CAAE47 fg:#A29718)\
$directory\
[Óāį](fg:#CAAE47 bg:#D9B558)\
$git_branch\
$git_status\
[Óāį](fg:#D9B558 bg:#9EAFA4)\
$c\
$elixir\
$elm\
$golang\
$gradle\
$haskell\
$java\
$julia\
$nodejs\
$nim\
$rust\
$scala\
[Óāį](fg:#9EAFA4 bg:#A4C1B3)\
$docker_context\
[Óāį](fg:#A4C1B3 bg:#B8C7BA)\
$time\
[Óāį ](fg:#B8C7BA)\
"""

# Disable the blank line at the start of the prompt
# add_newline = false

# You can also replace your username with a neat symbol like ÔĄ†  or disable this
# and use the os module below
[username]
show_always = true
style_user = "bg:#A29718"
style_root = "bg:#A29718"
format = '[$user ](fg:#000000 $style)'
disabled = false

# An alternative to the username module which displays a symbol that
# represents the current operating system
[os]
style = "bg:#A29718"
disabled = true # Disabled by default

[directory]
style = "bg:#CAAE47"
format = "[ $path ](fg:#000000 $style)"
truncation_length = 3
truncation_symbol = "‚Ä¶/"

# Here is how you can shorten some long paths by text replacement
# similar to mapped_locations in Oh My Posh:
[directory.substitutions]
"Documents" = "ůįąô "
"Downloads" = "ÔÄô "
"Music" = "ÔÄĀ "
"Pictures" = "ÔÄĺ "
# Keep in mind that the order matters. For example:
# "Important Documents" = " ůįąôÔĄ™ "
# will not be replaced, because "Documents" was already substituted before.
# So either put "Important Documents" before "Documents" or use the substituted version:
# "Important ůįąô " = " ůįąôÔĄ™ "

[c]
symbol = "Óėě "
style = "bg:#9EAFA4"
format = '[ $symbol ($version) ](fg:#000000 $style)'

[docker_context]
symbol = "ÔĆą "
style = "bg:#A4C1B3"
format = '[ $symbol $context ](fg:#000000 $style)'

[elixir]
symbol = "ÓČĶ "
style = "bg:#9EAFA4"
format = '[ $symbol ($version) ](fg: #000000$style)'

[elm]
symbol = "Óė¨ "
style = "bg:#9EAFA4"
format = '[ $symbol ($version) ](fg:#000000 $style)'

[git_branch]
symbol = "Ôźė"
style = "bg:#D9B558"
format = '[ $symbol $branch ](fg:#000000 $style)'

[git_status]
style = "bg:#D9B558"
format = '[$all_status$ahead_behind ](fg:#000000 $style)'

[golang]
symbol = "Óėß "
style = "bg:#9EAFA4"
format = '[ $symbol ($version) ](fg:#000000 $style)'

[gradle]
style = "bg:#9EAFA4"
format = '[ $symbol ($version) ](fg:#000000 $style)'

[haskell]
symbol = "ÓĚ∑ "
style = "bg:#9EAFA4"
format = '[ $symbol ($version) ](fg:#000000 $style)'

[java]
symbol = "ÓČĖ "
style = "bg:#9EAFA4"
format = '[ $symbol ($version) ](fg:#000000 $style)'

[julia]
symbol = "Óė§ "
style = "bg:#9EAFA4"
format = '[ $symbol ($version) ](fg:#000000 $style)'

[nodejs]
symbol = "Óúė"
style = "bg:#9EAFA4"
format = '[ $symbol ($version) ](fg:#000000 $style)'

[nim]
symbol = "ůįÜ• "
style = "bg:#9EAFA4"
format = '[ $symbol ($version) ](fg:#000000 $style)'

[rust]
symbol = "Óě®"
style = "bg:#9EAFA4"
format = '[ $symbol ($version) ](fg:#000000 $style)'

[scala]
symbol = "Óú∑ "
style = "bg:#9EAFA4"
format = '[ $symbol ($version) ](fg:#000000 $style)'

[time]
disabled = false
time_format = "%R" # Hour:Minute Format
style = "bg:#B8C7BA"
format = '[ ůįčĎ $time ](fg:#000000 $style)'
