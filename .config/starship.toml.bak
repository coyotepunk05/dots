format = """
[Óā∂](#6E7A8E)\
$os\
$username\
[Óāį](bg:#7A88B1 fg:#6E7A8E)\
$directory\
[Óāį](fg:#7A88B1 bg:#68ACE7)\
$git_branch\
$git_status\
[Óāį](fg:#68ACE7 bg:#A4ACB2)\
$c\
$elixir\
$elm\
$golang\
$gradle\
$haskell\
$java\
$julia\
$nodejs\
$nim\
$rust\
$scala\
[Óāį](fg:#A4ACB2 bg:#E4CD94)\
$docker_context\
[Óāį](fg:#E4CD94 bg:#A3D3F3)\
$time\
[Óāį ](fg:#A3D3F3)\
"""

# Disable the blank line at the start of the prompt
# add_newline = false

# You can also replace your username with a neat symbol like ÔĄ†  or disable this
# and use the os module below
[username]
show_always = true
style_user = "bg:#6E7A8E"
style_root = "bg:#6E7A8E"
format = '[$user ](fg:#FFFFFF $style)'
disabled = false

# An alternative to the username module which displays a symbol that
# represents the current operating system
[os]
style = "bg:#6E7A8E"
disabled = true # Disabled by default

[directory]
style = "bg:#7A88B1"
format = "[ $path ](fg:#FFFFFF $style)"
truncation_length = 3
truncation_symbol = "‚Ä¶/"

# Here is how you can shorten some long paths by text replacement
# similar to mapped_locations in Oh My Posh:
[directory.substitutions]
"Documents" = "ůįąô "
"Downloads" = "ÔÄô "
"Music" = "ÔÄĀ "
"Pictures" = "ÔÄĺ "
# Keep in mind that the order matters. For example:
# "Important Documents" = " ůįąôÔĄ™ "
# will not be replaced, because "Documents" was already substituted before.
# So either put "Important Documents" before "Documents" or use the substituted version:
# "Important ůįąô " = " ůįąôÔĄ™ "

[c]
symbol = "Óėě "
style = "bg:#A4ACB2"
format = '[ $symbol ($version) ](fg:#FFFFFF $style)'

[docker_context]
symbol = "ÔĆą "
style = "bg:#E4CD94"
format = '[ $symbol $context ](fg:#FFFFFF $style)'

[elixir]
symbol = "ÓČĶ "
style = "bg:#A4ACB2"
format = '[ $symbol ($version) ](fg: #FFFFFF$style)'

[elm]
symbol = "Óė¨ "
style = "bg:#A4ACB2"
format = '[ $symbol ($version) ](fg:#FFFFFF $style)'

[git_branch]
symbol = "Ôźė"
style = "bg:#68ACE7"
format = '[ $symbol $branch ](fg:#FFFFFF $style)'

[git_status]
style = "bg:#68ACE7"
format = '[$all_status$ahead_behind ](fg:#FFFFFF $style)'

[golang]
symbol = "Óėß "
style = "bg:#A4ACB2"
format = '[ $symbol ($version) ](fg:#FFFFFF $style)'

[gradle]
style = "bg:#A4ACB2"
format = '[ $symbol ($version) ](fg:#FFFFFF $style)'

[haskell]
symbol = "ÓĚ∑ "
style = "bg:#A4ACB2"
format = '[ $symbol ($version) ](fg:#FFFFFF $style)'

[java]
symbol = "ÓČĖ "
style = "bg:#A4ACB2"
format = '[ $symbol ($version) ](fg:#FFFFFF $style)'

[julia]
symbol = "Óė§ "
style = "bg:#A4ACB2"
format = '[ $symbol ($version) ](fg:#FFFFFF $style)'

[nodejs]
symbol = "Óúė"
style = "bg:#A4ACB2"
format = '[ $symbol ($version) ](fg:#FFFFFF $style)'

[nim]
symbol = "ůįÜ• "
style = "bg:#A4ACB2"
format = '[ $symbol ($version) ](fg:#FFFFFF $style)'

[rust]
symbol = "Óě®"
style = "bg:#A4ACB2"
format = '[ $symbol ($version) ](fg:#FFFFFF $style)'

[scala]
symbol = "Óú∑ "
style = "bg:#A4ACB2"
format = '[ $symbol ($version) ](fg:#FFFFFF $style)'

[time]
disabled = false
time_format = "%R" # Hour:Minute Format
style = "bg:#A3D3F3"
format = '[ ůįčĎ $time ](fg:#FFFFFF $style)'
